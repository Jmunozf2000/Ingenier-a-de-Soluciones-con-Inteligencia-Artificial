        "type": "prometheus",
        "uid": "prometheus_ra3"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ra3"
